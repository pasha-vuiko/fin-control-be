{
  "name": "fin-control-be",
  "version": "1.0.0",
  "private": true,
  "description": "BE for self finances tracking application",
  "license": "UNLICENSED",
  "author": "",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "postinstall": "patch-package --error-on-fail",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "migrations:run": "prisma migrate deploy",
    "prisma:generate": "prisma generate",
    "sonar": "node --env-file=.env sonar-scanner.mjs",
    "start": "node --env-file=.env dist/src/main.js",
    "start:bun": "bun run dist/src/main.js",
    "start:debug": "nest start --debug --watch -e 'node --env-file=.env'",
    "start:dev": "nest start --watch -e 'node --env-file=.env'",
    "start:prod": "node --enable-source-maps dist/src/main",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "test:debug": "vitest --inspect-brk --inspect --logHeapUsage --no-file-parallelism",
    "test:e2e": "vitest run --config ./test/vitest.config.e2e.mjs",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fastify/static": "^9.1.1",
    "@fastify/under-pressure": "^9.0.3",
    "@geut/fastify-uws": "^6.0.0",
    "@keyv/valkey": "^1.0.11",
    "@nestjs/cache-manager": "^3.1.0",
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "@nestjs/platform-fastify": "^11.1.19",
    "@nestjs/swagger": "^11.3.0",
    "@node-rs/jsonwebtoken": "^0.5.9",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "async-cache-dedupe": "^3.4.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "drizzle-orm": "^1.0.0-beta.1-578e9fd",
    "fastify": "^5.8.5",
    "fastify-metrics": "^13.2.0",
    "fastify-plugin": "^5.1.0",
    "get-jwks": "^11.0.3",
    "ioredis": "^5.10.1",
    "keyv": "^5.6.0",
    "pg": "^8.20.0",
    "pg-error-enum": "^2.0.1",
    "pg-native": "^3.7.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prisma-error-enum": "^0.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "undici": "^8.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.19",
    "@semantic-release/git": "^10.0.1",
    "@sonar/scan": "^4.3.6",
    "@swc/core": "^1.15.26",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/k6": "^1.7.0",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@types/validator": "^13.15.10",
    "@vitest/coverage-v8": "^4.1.4",
    "drizzle-prisma-generator": "^0.1.7",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-security": "^4.0.0",
    "globals": "^17.5.0",
    "patch-package": "^8.0.1",
    "prettier": "^3.8.3",
    "prisma": "^7.7.0",
    "semantic-release": "^25.0.3",
    "supertest": "^7.2.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": "24.15.0"
  },
  "overrides": {
    "fastify": "^5.8.5",
    "@geut/fastify-uws": {
      "uWebSockets.js": "github:uNetworking/uWebSockets.js#v20.55.0"
    }
  }
}
